@page
@model PetShop.Pages.Home.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = "_LayoutLogin";
}

<head>
    <meta name="viewport" content="width=device-width" />
    <title>Login</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
</head>

<body class="bg-light">
    <div class="container vh-100 d-flex justify-content-center align-items-center">
        <div class="card shadow p-4" style="width: 400px; border-radius: 15px;">
            <div class="text-center mb-4">
                <img src="~/images/logo.jpeg" width="200" height="100" class="img-fluid rounded" />
            </div>
            <h2 class="text-center mb-4">
                Login
            </h2>
            <form method="post">
                <div class="mb-3">
                    <label class="form-label">
                        Email
                    </label>
                    <input asp-for="Input.Email" class="form-control" />
                </div>
                <div class="mb-4">
                    <label class="form-label">
                        Senha
                    </label>
                    <input asp-for="Input.Password" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary w-100">
                    Entrar
                </button>
            </form>
            <div asp-validation-summary="All" class="text-danger mt-3"></div>
        </div>
    </div>
</body>
