@page
@model PetShop.Pages.Animais.IndexModel
@{
    ViewData["Title"] = "Animais";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">
            Animais do cliente @Model.NomeCliente
        </h2>
        <a href="/Animais/Cadastrar?idCliente=@Model.IdCliente" class="btn btn-primary">Adicionar</a>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <table class="table table-hover align-middle" data-toggle="table" data-toolbar="#toolbar" data-search="true">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>Tipo de animal</th>
                        <th>Tem alergia?</th>
                        <th>Pode perfume?</th>
                        <th>Pode enfeite??</th>
                        <th width="180">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var animal in Model.Animais)
                    {
                        var temAlergia = animal.TemAlergia ? "Sim" : "Não";
                        var podePerfume = animal.PodePerfume ? "Sim" : "Não";
                        var podeEnfeite = animal.PodeEnfeite ? "Sim" : "Não";

                        <tr>
                            <td>
                                @animal.Nome
                            </td>
                            <td>
                                @animal.TipoAnimal
                            </td>
                            <td>
                                @temAlergia
                            </td>
                            <td>
                                @podePerfume
                            </td>
                            <td>
                                @podeEnfeite
                            </td>
                            <td>
                                <a asp-page="/Animais/Editar" asp-route-id="@animal.Id" class="btn btn-sm btn-warning" title="Editar">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <a class="btn btn-sm btn-danger" title="Excluir" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="@animal.Id" data-nome="@animal.Nome">
                                    <i class="fa-solid fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form method="post" asp-page-handler="Delete">
                            <div class="modal-header">
                                <h5 class="modal-title">
                                    Excluir animal
                                </h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal">
                                </button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" id="animalId" name="id" />
                                <p>
                                    Deseja realmente excluir o animal: <strong id="animalNome"></strong>?
                                </p>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                    Cancelar
                                </button>
                                <button type="submit" class="btn btn-danger">
                                    Excluir
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {

    <script>

        const deleteModal =document.getElementById('deleteModal');

        deleteModal.addEventListener('show.bs.modal',
            function (event) {
                const button = event.relatedTarget;

                const id = button.getAttribute('data-id');

                const nome = button.getAttribute('data-nome');

                document.getElementById('animalId').value = id;

                document.getElementById('animalNome').innerText = nome;
            });
    </script>
}
